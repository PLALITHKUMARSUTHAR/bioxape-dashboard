{
  "outputDirectory": "dist",
  "cleanUrls": false,
  "rewrites": [
    { "source": "/admin", "destination": "/admin.html" },
    { "source": "/author", "destination": "/author.html" },
    { "source": "/editor", "destination": "/editor.html" },
    { "source": "/login", "destination": "/login.html" },
    { "source": "/register", "destination": "/register.html" },
    { "source": "/store", "destination": "/store.html" },
    { "source": "/research", "destination": "/research.html" },
    { "source": "/category", "destination": "/category.html" },
    { "source": "/post", "destination": "/post.html" },
    { "source": "/tools/(.*)", "destination": "/forum/index.html" },
    { "source": "/tools", "destination": "/forum/index.html" },
    { "source": "/forum/(.*)", "destination": "/forum/index.html" },
    { "source": "/forum", "destination": "/forum/index.html" }
  ]
}
